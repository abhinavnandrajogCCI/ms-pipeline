# Ignore everything
*


# But not the src folder
!src/


# Allow everything inside src
!src/**


# Allow specific files
!mule-artifact.json
!pom.xml
!.gitignore


# Ignore .DS_Store files
.DS_Store


# Ignore all .wev files, regardless of nesting
*.wev

# Ignore application-types.xml files regardless of nesting
**/application-types.xml
